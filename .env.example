# last30days Configuration Example
# Copy this file to ~/.config/last30days/.env and configure your API keys

# ============================================================================
# API Keys (Traditional Setup)
# ============================================================================

# OpenAI API Key (for Reddit search)
# Get from: https://platform.openai.com/api-keys
#OPENAI_API_KEY=sk-...

# xAI API Key (for X/Twitter search)
# Get from: https://x.ai/api
#XAI_API_KEY=xai-...

# Web Search APIs (optional, for general web search)
#BRAVE_API_KEY=...
#PARALLEL_API_KEY=...
#OPENROUTER_API_KEY=...

# ============================================================================
# Ollama Configuration (Self-Hosted Alternative)
# ============================================================================

# Enable Ollama for Reddit search (instead of OpenAI)
#USE_OLLAMA_REDDIT=true
#OLLAMA_REDDIT_MODEL=llama3.1:70b

# Enable Ollama for X search (instead of xAI)
#USE_OLLAMA_X=true
#OLLAMA_X_MODEL=llama3.1:70b

# Ollama base URL (default: http://localhost:11434)
#OLLAMA_BASE_URL=http://localhost:11434

# ============================================================================
# X/Twitter Browser Cookie Source (for Bird CLI)
# ============================================================================

# Force specific browser for X authentication (avoids Chrome keychain prompts on macOS)
# Options: safari (recommended on Mac) | chrome | firefox
# If not set, tries: safari → chrome → firefox
#BIRD_COOKIE_SOURCE=safari

# ============================================================================
# Model Selection Policies (Advanced)
# ============================================================================

# OpenAI model policy: auto (default) | pinned
#OPENAI_MODEL_POLICY=auto
# If pinned, specify the model:
#OPENAI_MODEL_PIN=gpt-5.2

# xAI model policy: latest (default) | stable | pinned
#XAI_MODEL_POLICY=latest
# If pinned, specify the model:
#XAI_MODEL_PIN=grok-4-1-fast

# ============================================================================
# Example Configurations
# ============================================================================

# Example 1: Traditional API-based setup
#OPENAI_API_KEY=sk-proj-...
#XAI_API_KEY=xai-...
#BRAVE_API_KEY=BSA...

# Example 2: Fully local with Ollama (no API keys needed!)
#USE_OLLAMA_REDDIT=true
#USE_OLLAMA_X=true
#OLLAMA_REDDIT_MODEL=llama3.1:70b
#OLLAMA_X_MODEL=llama3.1:70b

# Example 3: Hybrid (OpenAI for Reddit, Ollama for X)
#OPENAI_API_KEY=sk-proj-...
#USE_OLLAMA_X=true
#OLLAMA_X_MODEL=llama3.1:70b

# Example 4: Ollama with remote server
#USE_OLLAMA_REDDIT=true
#USE_OLLAMA_X=true
#OLLAMA_BASE_URL=http://your-server:11434
#OLLAMA_REDDIT_MODEL=qwen2.5:32b
#OLLAMA_X_MODEL=qwen2.5:32b
